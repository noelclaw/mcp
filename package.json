{
  "name": "@noelclaw/mcp",
  "version": "3.30.3",
  "description": "The runtime layer for Agentic AI. 103 MCP tools: persistent memory, autonomous agents, vault storage, scheduled workflows, DeFi execution on Base, deep research, and Noel Shell tool calling — works in Claude Code, Cursor, Windsurf, Codex, Aeon, Antigravity, and any MCP-compatible client.",
  "main": "dist/index.js",
  "bin": {
    "noelclaw": "dist/cli.js",
    "noelclaw-mcp": "dist/index.js"
  },
  "preferGlobal": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "autonomous-agents",
    "persistent-memory",
    "memory-layer",
    "vault",
    "agentic",
    "workflow-automation",
    "claude-code",
    "cursor",
    "windsurf",
    "noelclaw",
    "research",
    "automation",
    "defi",
    "base-chain",
    "tool-calling",
    "noel-shell",
    "ai-terminal",
    "knowledge-graph",
    "semantic-search"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noelclaw/mcp.git"
  },
  "homepage": "https://github.com/noelclaw/mcp#readme",
  "bugs": {
    "url": "https://github.com/noelclaw/mcp/issues"
  },
  "license": "MIT",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ethers": "^6.16.0",
    "node-fetch": "^3.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
